# Usamos la imagen base súper ligera de Alpine
FROM python:3.10-alpine

# Evita que Python escriba archivos .pyc y fuerza que el output vaya directo a la terminal
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Copiamos e instalamos dependencias primero para aprovechar el caché de Docker
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copiamos el código de la app
COPY app.py .

EXPOSE 8000

# Ejecuta Gunicorn con 2 workers escuchando en el puerto 8000
CMD ["gunicorn", "-w", "2", "-b", "0.0.0.0:8000", "app:app"]